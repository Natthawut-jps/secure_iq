// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

// 1
model User {
  id    String    @id
  email String @unique
  password String
  name String
  status String
  version Int
  created_at DateTime
  updated_at DateTime
  sessions Session[]
  posts Post[]
  emailVerificationTokens EmailVerificationToken[]
  resetPasswordTokens ResetPasswordToken[]
  @@index([email])
}

// 2
model Session {
  id String @id
  selector String @unique
  token_hash String @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime
  updated_at DateTime
  user User @relation(fields: [user_id], references: [id])
  user_id String
  @@index([user_id])
}

model Post {
  id        String     @id
  title     String
  content   String
  tag       String
  author    User    @relation(fields: [userId], references: [id])
  userId    String
  created_at DateTime
  updated_at DateTime
  @@index([title])
  @@index([tag])
}

// 3
model EmailVerificationToken {
  id String @id
  user_id String
  email String
  token_hash String @unique
  is_used Boolean
  created_at DateTime
  expires_at DateTime
  user User @relation(fields: [user_id], references: [id])
  @@index([user_id])
  @@index([email])
}

// 4
model ResetPasswordToken {
  id String @id
  user_id String
  token_hash String @unique
  is_used Boolean
  created_at DateTime
  expires_at DateTime
  user User @relation(fields: [user_id], references: [id])
  @@index([user_id])
  @@index([token_hash])
}